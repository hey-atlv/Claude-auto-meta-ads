# Environment Variables
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Backend Firebase Admin SDK credential.
# Download a service account JSON from Firebase Console and set an absolute path.
# Example on Windows: GOOGLE_APPLICATION_CREDENTIALS=D:/atlv/Auto-Meta-Ads-main/firebase-service-account.json
GOOGLE_APPLICATION_CREDENTIALS=

GEMINI_API_KEY=

# ============================================================================
# AI SDK Input Normalization (Optional)
# ============================================================================

# Preferred key for @ai-sdk/google. GEMINI_API_KEY remains supported as fallback.
GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_GEMINI_API_KEY=
GOOGLE_GEMINI_MODEL=gemini-2.5-flash

# Keep false until staging tests pass. Use request body useAI=true for manual tests.
ETL_NORMALIZATION_MODE=hybrid
ETL_SCHEMA_NORMALIZE_ENABLED=true
ETL_AI_NORMALIZE_ENABLED=false
ETL_AI_ASSIST_ON_LOW_CONFIDENCE=true
ETL_MIN_NORMALIZATION_CONFIDENCE=0.85
ETL_FAIL_ON_CRITICAL_QUALITY_ERRORS=true
ETL_WRITE_QUALITY_REPORT=true
ETL_NORMALIZE_BEFORE_TRANSFORM=false
AI_NORMALIZE_BATCH_SIZE=25
AI_MAX_OUTPUT_TOKENS=4096
AI_MAX_TOKENS_PER_REQUEST=8000
AI_TOKEN_BUDGET_PER_DAY=1000000
AI_WARN_THRESHOLD_PERCENT=80

# ============================================================================
# ETL Service Configuration
# ============================================================================

# Google Sheets API Configuration
GOOGLE_SHEETS_API_KEY=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_SCAN_INTERVAL_MINUTES=60

# ETL Processing
ETL_BATCH_SIZE=400
ETL_VALIDATION_LEVEL=strict
ETL_AUTO_HEAL_ERRORS=true
ETL_DRY_RUN_MODE=false

# Data Sync Schedule (cron format)
# Default: 1:00 AM daily (Vietnam time)
SYNC_SCHEDULE_CRON=0 1 * * *

# Firestore Configuration
FIRESTORE_DATABASE_ID=(default)
FIRESTORE_QUOTA_LIMIT=20000
FIRESTORE_BATCH_WRITE_TIMEOUT_MS=60000

# ============================================================================
# Audit & Monitoring
# ============================================================================

# Audit Trail
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=90

# Quality Monitoring
DATA_QUALITY_CHECK_ENABLED=true
DATA_QUALITY_ALERT_THRESHOLD=95

# Error Recovery
ERROR_RECOVERY_ENABLED=true
ERROR_RETRY_ATTEMPTS=3
ERROR_RETRY_DELAY_MS=5000

# ============================================================================
# Development & Debugging
# ============================================================================

NODE_ENV=development
DEBUG_MODE=false
LOG_LEVEL=info
